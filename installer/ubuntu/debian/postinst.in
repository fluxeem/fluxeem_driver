# DEB 包安装后脚本：自动执行 USB 驱动安装
set -e

case "$1" in
  configure)
    SCRIPT="/usr/share/@PROJECT_NAME@/scripts/udev/install_usb_driver.sh"
    if [ -x "$SCRIPT" ]; then
      "$SCRIPT"
    else
      echo "Warning: USB install script not found or not executable: $SCRIPT"
    fi
    ;;
esac

exit 0
